# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://geo:geo@postgres:5432/geovision
DATABASE_URL_SYNC=postgresql+psycopg2://geo:geo@postgres:5432/geovision

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=geovision
MINIO_SECURE=false

# ── CDSE (Copernicus Data Space Ecosystem) ────────────────────────────────────
# Логин и пароль от аккаунта https://dataspace.copernicus.eu/
# Создавать отдельный OAuth client НЕ нужно
CDSE_USERNAME=your_email@gmail.com
CDSE_PASSWORD=your_password

# ── SIFT ──────────────────────────────────────────────────────────────────────
SIFT_N_FEATURES=2000
SIFT_CONTRAST_THRESHOLD=0.04
SIFT_EDGE_THRESHOLD=10
SIFT_SIGMA=1.6

# ── Preprocessing (эксперимент: сокращение domain gap UAV↔Sentinel-2) ─────────
# По умолчанию выключено = текущее поведение. При изменении нужно пересобрать
# словарь и индекс (build_vocabulary + build_index), т.к. предобработка влияет
# и на патчи базы, и на query одинаково.
PREPROCESS_RESIZE_SCALE=1.0
PREPROCESS_NORMALIZE_CHANNELS=false
PREPROCESS_USE_CLAHE=false
PREPROCESS_USE_LCN=false

# ── BoVW ──────────────────────────────────────────────────────────────────────
VOCAB_SIZE=1024
VOCAB_SAMPLE_PER_PATCH=50
VOCAB_KMEANS_N_INIT=10

# ── FAISS ─────────────────────────────────────────────────────────────────────
FAISS_N_LISTS=256
FAISS_N_PROBE=32
FAISS_INDEX_PATH=/data/index/patch_index.faiss
VOCAB_PATH=/data/index/vocabulary.pkl

# ── Tiling ────────────────────────────────────────────────────────────────────
PATCH_SIZE_PX=256
PATCH_OVERLAP_RATIO=0.25
PATCH_MIN_COVERAGE=0.8
PATCH_GSD_M=10.0

# ── Matching ──────────────────────────────────────────────────────────────────
RANSAC_THRESHOLD=5.0
LOWE_RATIO=0.75
TOP_N_COARSE=100
TOP_N_RESULT=10
MIN_GOOD_MATCHES=4

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
MAX_IMAGE_SIZE_MB=50
LOG_LEVEL=INFO
